# Copy to .env and fill in. app.config.yaml substitutes these into the action inputs.
# Do NOT commit .env.

OKTA_ISSUER=https://adobe.okta.com/oauth2/aus1gan31wnmCPyB60h8
ORG=vidobe
REPO=nash
IMS_SCOPES=openid,AdobeID,read_organizations,adobeio_api,additional_info.projectedProductContext

# DA source writes (admin.da.live) — OAuth Server-to-Server credential. The
# technical account must be granted WRITE on the DA site's permissions sheet.
IMS_CLIENT_ID=xxxxxxxx
IMS_CLIENT_SECRET=xxxxxxxx

# AEM preview/publish (admin.hlx.page) — a site Admin API key
# (create: POST admin.hlx.page/config/{org}/sites/{site}/apiKeys.json, roles:["publish"]).
AEM_API_KEY=xxxxxxxx

# Fallback only — a short-lived DA bearer token (used if IMS_CLIENT_* not set):
# DA_TOKEN=xxxxxxxx
